# ═══════════════════════════════════════════════════════════════════════════════
# SENTIX PRO - Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── REQUIRED ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Supabase (Database)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJ...your_anon_key

# ─── OPTIONAL SERVICES ────────────────────────────────────────────────────────

# Telegram Bot (alerts via Telegram)
# Create bot: Open Telegram > Search @BotFather > /newbot
TELEGRAM_BOT_TOKEN=

# Email Alerts (via Resend)
# Get key: https://resend.com/api-keys
RESEND_API_KEY=
ALERT_EMAIL=your@email.com

# Alpha Vantage (metals price data)
# Get key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# AI Analysis (optional)
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── FRONTEND URL (for CORS) ─────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.vercel.app
